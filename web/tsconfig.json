{
  "$schema": "https://json.schemastore.org/tsconfig",
  // Inlined from @docusaurus/tsconfig (3.10.1): TypeScript 7 removed
  // `baseUrl`, which the upstream preset still sets, so extending it fails
  // typecheck. `paths` entries below resolve relative to this file, which
  // reproduces the old `baseUrl: "."` behavior.
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "module": "esnext",
    "noEmit": true,
    "paths": {
      "@site/*": ["./*"],
      "*": ["./*"]
    },
    "skipLibCheck": true
  }
}
