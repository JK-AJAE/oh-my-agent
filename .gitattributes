# Default: treat all text files as text and force LF on checkout
# so Windows runners don't get CRLF (which Biome flags as a format error).
* text=auto eol=lf

# Shell scripts must stay LF regardless of platform.
*.sh text eol=lf
*.bash text eol=lf

# PowerShell scripts use CRLF natively; preserve as-is.
*.ps1 text eol=crlf

# Mark common binaries so they aren't touched.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.woff binary
*.woff2 binary
